GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# --- Google Classroom Integration ---
# Create these in Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
# Must match exactly what you register in Google Cloud Console
GOOGLE_REDIRECT_URI="https://your-app.vercel.app/api/google/callback"

# --- Supabase server-side (for API routes) ---
# SUPABASE_URL: same value as VITE_SUPABASE_URL
SUPABASE_URL="https://your-project.supabase.co"
# Service role key — never expose this to the browser
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# LLM provider config for AI assets workflow
# Choose either OpenAI-compatible or Anthropic per command via --provider

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Sentry error tracking ---
VITE_SENTRY_DSN=your-sentry-dsn
